# boost.ai Statistics API v2 — local dev configuration.
# Copy to .env and fill in. .env is git-ignored and must NEVER be committed.
# In production these are read from OpenOrchestrator (credential/constant) instead.

# Tenant subdomain, i.e. <BOOST_TENANT>.boost.ai
BOOST_TENANT=

# OAuth2 client_credentials (from Admin Panel -> Security & privacy -> OAuth 2.0)
BOOST_CLIENT_ID=
BOOST_CLIENT_SECRET=

# Scope string granting access to the Statistics API v2.
# For the ddh tenant the correct value is 'analytics:v1' (confirmed via the spike).
# Multiple scopes are separated by spaces.
BOOST_SCOPE=analytics:v1

# Date range for the spike (ISO-8601, timezone recommended). to_date is exclusive.
# Keep the range short while probing (e.g. 1-7 days) for fast responses.
SPIKE_FROM_DATE=2026-06-01T00:00:00+02:00
SPIKE_TO_DATE=2026-06-08T00:00:00+02:00
